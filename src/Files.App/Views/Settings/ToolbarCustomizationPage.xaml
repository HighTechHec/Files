<Page
	x:Class="Files.App.Views.Settings.ToolbarCustomizationPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="using:Files.App.Data.Behaviors"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:dataitem="using:Files.App.Data.Items"
	xmlns:helpers="using:Files.App.Helpers"
	xmlns:i="using:Microsoft.Xaml.Interactivity"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:uc="using:Files.App.UserControls"
	xmlns:viewmodels="using:Files.App.ViewModels.Settings"
	xmlns:wctconverters="using:CommunityToolkit.WinUI.Converters"
	x:Name="PageRoot"
	mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="ms-appx:///Styles/ToolbarButtonStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<x:Double x:Key="ToolbarAddedItemsActionColumnMinWidth">120</x:Double>
			<x:Double x:Key="ToolbarAddedItemsListMinWidth">384</x:Double>

			<wctconverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
			<wctconverters:BoolToVisibilityConverter
				x:Key="NegatedBoolToVisibilityConverter"
				FalseValue="Visible"
				TrueValue="Collapsed" />

			<SolidColorBrush x:Key="CommandBarBackground" Color="Transparent" />
			<SolidColorBrush x:Key="CommandBarBackgroundOpen" Color="Transparent" />
			<SolidColorBrush x:Key="CommandBarBorderBrushOpen" Color="Transparent" />

			<Style
				x:Key="ToolbarCustomizationRemoveButtonStyle"
				BasedOn="{StaticResource DefaultButtonStyle}"
				TargetType="Button">
				<Setter Property="Width" Value="32" />
				<Setter Property="Height" Value="24" />
				<Setter Property="MinWidth" Value="32" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="BorderBrush" Value="Transparent" />
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
			</Style>
		</ResourceDictionary>
	</Page.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<Grid
			x:Name="WindowTitleBar"
			Grid.Row="0"
			Height="36"
			Padding="12,0,160,0"
			Background="Transparent">
			<TextBlock
				VerticalAlignment="Center"
				Style="{StaticResource App.Theme.CaptionTextBlockStyle}"
				Text="{helpers:ResourceString Name=CustomizeToolbar}" />
		</Grid>

		<!--  Context picker  -->
		<Grid
			Grid.Row="1"
			Padding="16,12,16,12"
			ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<TextBlock VerticalAlignment="Center" Text="{helpers:ResourceString Name=ChooseToolbarModeToCustomize}" />

			<uc:ComboBoxEx
				Grid.Column="1"
				MinWidth="220"
				AutomationProperties.Name="{helpers:ResourceString Name=ChooseToolbarModeToCustomize}"
				DisplayMemberPath="Value"
				ItemsSource="{x:Bind ViewModel.ToolbarContexts, Mode=OneWay}"
				SelectedValue="{x:Bind ViewModel.SelectedToolbarContextId, Mode=TwoWay}"
				SelectedValuePath="Key" />
		</Grid>

		<!--  Available and Added items (scrollable)  -->
		<Grid
			Grid.Row="2"
			Padding="16,12,16,12"
			ColumnSpacing="12"
			RowSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="240" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!--  Left: Available items tree with its own explicit horizontal ScrollViewer  -->
			<Border
				Grid.Row="0"
				Grid.RowSpan="2"
				Grid.Column="0"
				Background="{ThemeResource LayerFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				CornerRadius="8">
				<ScrollViewer
					HorizontalScrollBarVisibility="Auto"
					HorizontalScrollMode="Enabled"
					VerticalScrollBarVisibility="Auto"
					VerticalScrollMode="Enabled">
					<TreeView
						AllowDrop="False"
						CanDragItems="True"
						DragItemsCompleted="AvailableToolbarItemsTree_DragItemsCompleted"
						DragItemsStarting="AvailableToolbarItemsTree_DragItemsStarting"
						ItemsSource="{x:Bind ViewModel.AvailableToolbarTreeItems, Mode=OneWay}"
						SelectionMode="Single">
						<TreeView.ItemTemplate>
							<DataTemplate x:DataType="viewmodels:ToolbarAvailableTreeItem">
								<TreeViewItem Content="{x:Bind DisplayName}" ItemsSource="{x:Bind Children}" />
							</DataTemplate>
						</TreeView.ItemTemplate>
					</TreeView>
				</ScrollViewer>
			</Border>

			<!--  Right: sticky header with XAML-defined baseline widths so rows align like a data grid.  -->
			<Border
				Grid.Row="0"
				Grid.RowSpan="2"
				Grid.Column="1"
				Background="Transparent"
				BorderBrush="Transparent"
				BorderThickness="0"
				CornerRadius="8">
				<ListView
					x:Name="ToolbarItemsList"
					Padding="0"
					HorizontalContentAlignment="Stretch"
					AllowDrop="True"
					Background="Transparent"
					BorderThickness="0"
					CanDragItems="True"
					CanReorderItems="True"
					ContainerContentChanging="ToolbarItemsList_ContainerContentChanging"
					CornerRadius="0"
					DragOver="AddedToolbarItemsList_DragOver"
					Drop="AddedToolbarItemsList_Drop"
					ItemsSource="{x:Bind ViewModel.ToolbarItems, Mode=OneWay}"
					ReorderMode="Enabled"
					ScrollViewer.HorizontalScrollBarVisibility="Auto"
					ScrollViewer.HorizontalScrollMode="Enabled"
					ScrollViewer.VerticalScrollBarVisibility="Auto"
					ScrollViewer.VerticalScrollMode="Enabled"
					SelectionMode="None">
					<i:Interaction.Behaviors>
						<behaviors:StickyHeaderBehavior />
					</i:Interaction.Behaviors>

					<ListView.Header>
						<Border
							MinWidth="{StaticResource ToolbarAddedItemsListMinWidth}"
							HorizontalAlignment="Stretch"
							Background="{ThemeResource LayerFillColorDefaultBrush}"
							BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
							BorderThickness="1"
							CornerRadius="8">
							<Grid
								Padding="8,4"
								HorizontalAlignment="Stretch"
								ColumnSpacing="8">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="8" />
									<ColumnDefinition Width="*" MinWidth="{StaticResource ToolbarAddedItemsActionColumnMinWidth}" />
									<ColumnDefinition Width="24" />
									<ColumnDefinition Width="64" />
									<ColumnDefinition Width="64" />
									<ColumnDefinition Width="32" />
								</Grid.ColumnDefinitions>

								<Border
									Grid.Column="2"
									Width="1"
									Margin="0,-4,-4,-4"
									HorizontalAlignment="Right"
									Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

								<Border
									Grid.Column="3"
									Width="1"
									Margin="0,-4,-4,-4"
									HorizontalAlignment="Right"
									Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

								<Border
									Grid.Column="4"
									Width="1"
									Margin="0,-4,-4,-4"
									HorizontalAlignment="Right"
									Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

								<TextBlock
									Grid.Column="1"
									FontSize="12"
									FontWeight="SemiBold"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									Text="{helpers:ResourceString Name=Action}"
									TextWrapping="NoWrap" />

								<TextBlock
									Grid.Column="3"
									Margin="8,0,0,0"
									HorizontalAlignment="Left"
									FontSize="12"
									FontWeight="SemiBold"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									Text="Icon"
									TextWrapping="NoWrap" />

								<TextBlock
									Grid.Column="4"
									Margin="8,0,0,0"
									HorizontalAlignment="Left"
									FontSize="12"
									FontWeight="SemiBold"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									Text="Label"
									TextWrapping="NoWrap" />
							</Grid>
						</Border>
					</ListView.Header>

					<ListView.ItemTemplate>
						<DataTemplate x:DataType="dataitem:ToolbarItemDescriptor">
							<Grid
								MinWidth="{StaticResource ToolbarAddedItemsListMinWidth}"
								Padding="4,0,4,0"
								HorizontalAlignment="Stretch"
								ColumnSpacing="8">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="8" />
									<ColumnDefinition Width="*" MinWidth="{StaticResource ToolbarAddedItemsActionColumnMinWidth}" />
									<ColumnDefinition Width="24" />
									<ColumnDefinition Width="64" />
									<ColumnDefinition Width="64" />
									<ColumnDefinition Width="32" />
								</Grid.ColumnDefinitions>

								<PathIcon
									Grid.Column="0"
									VerticalAlignment="Center"
									Data="{StaticResource App.Theme.PathIcon.DragGripper}"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

								<TextBlock
									Grid.Column="1"
									VerticalAlignment="Center"
									Text="{x:Bind ExtendedDisplayNameWithGroupSuffix}"
									TextTrimming="CharacterEllipsis"
									TextWrapping="NoWrap"
									ToolTipService.ToolTip="{x:Bind ExtendedDisplayNameWithGroupSuffix}" />

								<CheckBox
									Grid.Column="3"
									Width="20"
									MinWidth="0"
									Margin="4,0,0,0"
									Padding="0"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									AutomationProperties.Name="{helpers:ResourceString Name=ShowToolbarIconOnly}"
									IsChecked="{x:Bind ShowIcon, Mode=TwoWay}"
									IsEnabled="{x:Bind HasIcon, Mode=OneWay}"
									ToolTipService.ToolTip="{helpers:ResourceString Name=ShowToolbarIconOnly}"
									Visibility="{x:Bind IsSeparator, Converter={StaticResource NegatedBoolToVisibilityConverter}}" />

								<CheckBox
									Grid.Column="4"
									Width="20"
									MinWidth="0"
									Margin="4,0,0,0"
									Padding="0"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									AutomationProperties.Name="{helpers:ResourceString Name=ShowToolbarLabels}"
									IsChecked="{x:Bind ShowLabel, Mode=TwoWay}"
									ToolTipService.ToolTip="{helpers:ResourceString Name=ShowToolbarLabels}"
									Visibility="{x:Bind IsSeparator, Converter={StaticResource NegatedBoolToVisibilityConverter}}" />

								<Button
									Grid.Column="5"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									AutomationProperties.Name="{helpers:ResourceString Name=Remove}"
									Command="{Binding ElementName=PageRoot, Path=DataContext.RemoveToolbarItemCommand, Mode=OneWay}"
									CommandParameter="{x:Bind}"
									Style="{StaticResource ToolbarCustomizationRemoveButtonStyle}"
									ToolTipService.ToolTip="{helpers:ResourceString Name=Remove}">
									<Button.Resources>
										<StaticResource x:Key="ButtonForegroundPointerOver" ResourceKey="SystemFillColorCriticalBrush" />
									</Button.Resources>
									<FontIcon FontSize="14" Glyph="&#xE711;" />
								</Button>
							</Grid>
						</DataTemplate>
					</ListView.ItemTemplate>

					<ListView.ItemContainerStyle>
						<Style TargetType="ListViewItem">
							<Setter Property="Margin" Value="0" />
							<Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
							<Setter Property="BorderThickness" Value="0,0,0,1" />
							<Setter Property="Padding" Value="0" />
							<Setter Property="MinHeight" Value="34" />
							<Setter Property="HorizontalAlignment" Value="Stretch" />
							<Setter Property="HorizontalContentAlignment" Value="Stretch" />
						</Style>
					</ListView.ItemContainerStyle>
				</ListView>
			</Border>
		</Grid>

		<!--  Preview  -->
		<StackPanel
			Grid.Row="3"
			Padding="16,0,16,0"
			Spacing="12">
			<Grid
				Padding="12"
				Background="{ThemeResource LayerFillColorDefaultBrush}"
				BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
				BorderThickness="1"
				CornerRadius="8">
				<ScrollViewer
					HorizontalContentAlignment="Center"
					HorizontalScrollBarVisibility="Auto"
					HorizontalScrollMode="Enabled"
					VerticalScrollBarVisibility="Disabled"
					VerticalScrollMode="Disabled">
					<CommandBar
						x:Name="PreviewCommandBar"
						HorizontalAlignment="Center"
						DefaultLabelPosition="Right"
						IsDynamicOverflowEnabled="False" />
				</ScrollViewer>
			</Grid>
		</StackPanel>

		<!--  Footer with Reset (left) and Save/Cancel (right)  -->
		<Grid
			Grid.Row="4"
			Padding="16,12"
			ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<Button
				Grid.Column="0"
				Command="{x:Bind ViewModel.ResetToolbarCommand, Mode=OneWay}"
				Content="{helpers:ResourceString Name=ResetDefaults}" />

			<StackPanel
				Grid.Column="2"
				HorizontalAlignment="Right"
				Orientation="Horizontal"
				Spacing="8">
				<Button
					MinWidth="96"
					Command="{x:Bind ViewModel.SaveToolbarCommand, Mode=OneWay}"
					Content="{helpers:ResourceString Name=Save}"
					IsEnabled="{x:Bind ViewModel.HasToolbarChanges, Mode=OneWay}"
					Style="{StaticResource AccentButtonStyle}" />
				<Button
					MinWidth="96"
					Command="{x:Bind ViewModel.CancelToolbarCommand, Mode=OneWay}"
					Content="{helpers:ResourceString Name=Cancel}" />
			</StackPanel>
		</Grid>
	</Grid>
</Page>
